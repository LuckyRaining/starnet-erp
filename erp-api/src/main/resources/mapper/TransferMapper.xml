<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="net.starnet.erp.wc.dao.TransferDao">


    <resultMap type="com.alibaba.fastjson.JSONObject" id="resultObj"></resultMap>

    <select id="queryPage" parameterType="com.alibaba.fastjson.JSONObject"
            resultType="net.starnet.erp.wc.model.Transfer">
        SELECT t.* from wc_transfer t WHERE 1 = 1
        <!-- 根据 “单据编号” 查询！ -->
        <if test="query.name != null and query.name != ''">
            AND t.`code` LIKE concat('%', #{query.name}, '%')
        </if>
        <!-- 根据 “startDate” <= “单据日期”wc_transfer.issueDate <= “endDate” 查询！ -->
        <if test="query.startDate != null and query.startDate != ''">
            AND t.`issueDate` <![CDATA[ >= ]]> #{query.startDate}
        </if>
        <if test="query.endDate != null and query.endDate != ''">
            AND t.`issueDate` <![CDATA[ <= ]]> #{query.endDate}
        </if>
        <!-- 根据 “createdTime” 降序！ -->
        ORDER BY t.createdTime DESC
    </select>

</mapper>